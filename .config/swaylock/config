# ~/.config/matugen/templates/swaylock.conf

image=~/Pictures/wallpaper.jpg
show-failed-attempts
ignore-empty-password
indicator-idle-visible
font=JetBrains Mono Nerd Font
line-uses-inside

# Outside (background)
color=#19120dff

# Text
text-color=#f0dfd7ff
text-clear-color=#ffdbc8ff
text-ver-color=#ffdbc8ff
text-wrong-color=#ffdad6ff
text-caps-lock-color=#e7e5acff

# Ring
ring-color=#ffb689ff
ring-clear-color=#e5bfa9ff
ring-ver-color=#ffb689ff
ring-wrong-color=#ffb4abff
ring-caps-lock-color=#cbc992ff

# Inside
inside-color=#261e19cc
inside-clear-color=#5c4130cc
inside-ver-color=#6e3810cc
inside-wrong-color=#93000acc
inside-caps-lock-color=#49491ecc

# Separator
separator-color=#52443c00

# Highlights
key-hl-color=#6e3810ff
caps-lock-key-hl-color=#cbc992ff
bs-hl-color=#ffb4abff
caps-lock-bs-hl-color=#ffb4abff

# Layout
layout-bg-color=#261e19aa
layout-border-color=#9f8d83ff
layout-text-color=#f0dfd7ff
