# Import the WAYLAND_DISPLAY env var from sway into the systemd user session.
dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP=wlr

# Stop any services that are running, so that they receive the new env var when they restart.
systemctl --user stop pipewire pipewire-media-session xdg-desktop-portal xdg-desktop-portal-wlr
systemctl --user start pipewire-media-session


# set up displays when connected to my monitor
OUTPUT="HDMI-A-1"
INTERNAL="eDP-1"

if wlr-randr | grep "^$OUTPUT " | grep -q "MSI MP275"; then
  echo "$OUTPUT detected. Applying configuration..."

  wlr-randr --output "$OUTPUT" --mode 1920x1080@100 --on
  wlr-randr --output "$INTERNAL" --off

  echo "Done."
else
  echo "$OUTPUT not found."
fi



dwmblocks | kwm &

kill -49 $(pidof dwmblocks)
kill -44 $(pidof dwmblocks)
